{
  "experiment_name": "baseline_eqm_s2_cifar10",
  "description": "Baseline EqM-S/2 on CIFAR-10, 1 epoch, NO mining. Establishes baseline short_horizon_recovery_distance.",

  "patch_size": 4,
  "hidden_size": 384,
  "depth": 12,
  "num_heads": 6,
  "uncond": true,
  "ebm": "none",

  "learning_rate": 1e-4,
  "weight_decay": 0.0,
  "batch_size": 128,
  "epochs": 1,
  "data_dir": "./data",

  "c_type": "truncated",
  "c_a": 0.8,
  "c_lambda": 4.0,

  "use_mining": false,
  "gamma": 0.0,

  "output_dir": "projects/diff-EqM/results/baseline"
}
