  "_comment": "Copy to baselines/vendor/sia/sia/defaults/providers/gpt-oss.json (or your SIA config dir). NO real keys here; key is read from the env var named below. Nebius Token Factory serves gpt-oss-120b on an OpenAI-compatible API; for vLLM/local set base_url to your server, e.g. http://localhost:8000/v1.",
  "provider_id": "gpt-oss",
  "name": "gpt-oss OpenAI-compatible endpoint",
  "client_kind": "openai",
  "base_url": "https://api.tokenfactory.nebius.com/v1/",
  "api_key_env": "NEBIUS_API_KEY"
}
