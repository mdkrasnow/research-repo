  "use_scalar_energy": true,
  "use_ired_contrastive_loss": true,
  "detach_epos_contrastive": true,
  "contrastive_temperature": 1000.0,
  "use_langevin": true,
  "mining_opt_steps": 1,
  "mining_noise_scale": 0.1,
  "langevin_sigma_multiplier": 0.05,
  "use_replay_buffer": true,
