{
  "experiment_name": "q237_ood_evaluation",
  "description": "OOD robustness evaluation of q237 (score smoothing sigma=0.01) checkpoint. Control — smoothing was inert.",
  "investigation": "ired-robustness",
  "evaluation_mode": true,
  "mining_strategy": "tam",
  "tam_anchor_step": 2,
  "pgd_delta": 1.5,
  "pgd_step_size": 0.5,
  "mining_opt_steps": 3,
  "use_recovery_loss": true,
  "recovery_steps": 1,
  "recovery_loss_weight": 0.1,
  "recovery_target": "implied_noise",
  "use_recovery_rank_loss": true,
  "recovery_rank_margin": 0.1,
  "recovery_rank_weight": 0.2,
  "score_smooth_sigma": 0.01,
  "score_smooth_weight": 0.001,
  "use_gradient_contrastive": false,
  "energy_loss_weight": 0.0,
  "use_scalar_energy": true,
  "rank": 20,
  "ood": true,
  "dataset": "inverse",
  "batch_size": 2048,
  "num_test_samples": 1024,
  "num_opt_steps": 10,
  "target_mse_threshold": 0.001,
  "diffusion_steps": 10,
  "learning_rate": 0.0001,
  "adam_betas": [0.0, 0.999],
  "model_checkpoints": [
    "projects/ired/results/ds_inverse/q237_score_smoothing/model-100.pt"
  ],
  "output_dir": "projects/ired/results/evaluation/q237_score_smoothing_ood",
  "notes": "OOD control eval: q237 smoothing was inert (smooth~0). Expected same as q232 (~0.213)."
}
