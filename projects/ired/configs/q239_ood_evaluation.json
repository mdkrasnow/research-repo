{
  "experiment_name": "q239_ood_evaluation",
  "description": "OOD robustness evaluation of q239 trajectory-CVaR 100K checkpoint.",
  "investigation": "ired-robustness",
  "evaluation_mode": true,
  "mining_strategy": "tam",
