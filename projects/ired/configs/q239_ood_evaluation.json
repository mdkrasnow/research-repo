  "learning_rate": 0.0001,
  "adam_betas": [0.0, 0.999],
  "model_checkpoints": [
    "projects/ired/results/ds_inverse/q239_trajectory_cvar_100k/model-100.pt"
  ],
  "output_dir": "projects/ired/results/evaluation/q239_trajectory_cvar_ood",
  "notes": "OOD eval of trajectory-CVaR training. Baseline OOD MSE=0.2063, TAM-CTL=0.2135. Key test: does rollout-state training improve OOD?"
